APP_ENV=local
POSTGRES_DB=livelines
POSTGRES_USER=livelines
POSTGRES_PASSWORD=replace-with-local-postgres-password
DATABASE_URL=postgresql+psycopg://livelines:replace-with-local-postgres-password@postgres:5432/livelines
REDIS_URL=redis://redis:6379/0
ENCRYPTION_KEY=replace-with-32-byte-base64-or-long-random-secret
SESSION_SECRET=replace-with-long-random-session-secret
INIT_TOKEN=change-me-before-use
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=replace-with-password-hash-placeholder
AUTH_LOGIN_MAX_ATTEMPTS=5
AUTH_LOGIN_WINDOW_SECONDS=600
AUTH_LOGIN_LOCK_SECONDS=900
COOKIE_SECURE=false
COOKIE_SAMESITE=lax
SESSION_TTL_SECONDS=86400
TEMP_CREDENTIAL_TTL_SECONDS=1800
SSH_CONNECT_TIMEOUT_SECONDS=15
SSH_COMMAND_TIMEOUT_SECONDS=10
SSH_INSTALL_TIMEOUT_SECONDS=300
FRONTEND_ORIGIN=http://localhost:3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
